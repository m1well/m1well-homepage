{% set posts = collections.blogPosts %}

<section id="blog">
  <h2 class="mw-section-title">Blog Posts</h2>
  <div class="mw-grid-2">
    {% for post in posts %}
    <div class="mw-card mw-card-content">
      <div class="mw-card-body">
        <h3 class="mw-card-title">{{ post.title }}</h3>
        <p class="mw-card-text mw-mt-5 mw-mb-1">{{ post.description }}</p>
        <div class="mw-card-footer">
          <a href="{{ post.link }}" class="mw-btn mw-btn-primary mw-btn-icon">
            <i class="fas fa-book-open"></i>
            Read Post
          </a>
          <span class="mw-text-secondary"
            >Published:<wbr /> {{ post.publishedDate }}</span
          >
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</section>
