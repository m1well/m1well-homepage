<div class="mw-container">
  <h2 class="mw-section-title">Professional Journey</h2>
  <div class="mw-timeline-big">
    {% for job in jobs %}
    <div class="mw-timeline-big-step">
      <div class="mw-timeline-big-date-container">
        <div class="mw-timeline-big-date-main">{{ job.time }}</div>
        {% if job.timerange %}
        <div class="mw-timeline-big-date-sub">({{ job.timerange }})</div>
        {% endif %}
      </div>
      <div class="mw-timeline-big-content">
        <div class="mw-card mw-card-content">
          <div class="mw-card-body">
            <h3 class="mw-card-title">{{ job.title }}</h3>
            <p class="mw-card-subtitle">
              {{ job.company }} | {{ job.location }}
            </p>
            <p class="mw-card-text">{{ job.description }}</p>
          </div>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
</div>
